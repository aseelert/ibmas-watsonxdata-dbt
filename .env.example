# Copy this file to .env and replace placeholders with values from your
# watsonx.data / IBM Software Hub environment. Do not commit .env.

# Presto / dbt connection.
# Find these values in the watsonx.data connection JSON or in the Presto engine
# details page. For API-key auth, the Presto user is usually:
# ibmlhapikey_<software-hub-username>
WXD_CPD_USERNAME=cpadmin
WXD_USER=ibmlhapikey_cpadmin
# SECRET — paste your Software Hub API key here. It is NOT in the connection
# JSON; prepare_watsonx_env.py never writes it. Generate it in the Software Hub
# console under Profile and settings -> API key.
WXD_API_KEY=replace-with-your-software-hub-api-key
WXD_CATALOG=iceberg_data
# dbt medallion schemas: dbt_demo_{raw,bronze,silver,gold}
WXD_SCHEMA=dbt_demo
# cpdctl native-ingest raw landing (consumed by the Spark pipeline).
WXD_INGEST_SCHEMA=spark_demo_cpdctl_raw
WXD_HOST=ibm-lh-lakehouse-presto651-presto-svc.apps.watson.ibmas-zocp-techcluster.org
WXD_PORT=443
WXD_INSTANCE_ID=1781163689818519
WXD_PRESTO_ENGINE_ID=presto651
WXD_SSL_VERIFY=certs/watsonxdata-ca.pem
WXD_GOLD_MATERIALIZED=view

# IBM Software Hub / CPD endpoints.
# WXD_CPD_HOST comes from the Software Hub route. The Spark endpoint is shown
# on the watsonx.data Spark engine details page.
WXD_CPD_HOST=cpd-cpd-instance.apps.watson.ibmas-zocp-techcluster.org
WXD_CPD_AUTH_URL=https://cpd-cpd-instance.apps.watson.ibmas-zocp-techcluster.org/icp4d-api/v1/authorize
WXD_OPENSHIFT_CONSOLE=https://console-openshift-console.apps.watson.ibmas-zocp-techcluster.org/
WXD_OPENSHIFT_API=https://api.watson.ibmas-zocp-techcluster.org:6443

# Optional: override the three medallion namespaces.
# WXD_BRONZE_SCHEMA=dbt_demo_bronze
# WXD_SILVER_SCHEMA=dbt_demo_silver
# WXD_GOLD_SCHEMA=dbt_demo_gold

# Optional: pin dbt + cpdctl schemas to an explicit location. Leave UNSET to use the
# catalog default warehouse (bucket root) — this matches where the watsonx.data Spark
# engine is forced to write (it ignores per-schema locations), keeping all engines
# uniform at bucket root. Only takes effect when a schema is first created; use
# `python scripts/bootstrap_watsonxdata.py --recreate` to relocate existing schemas.
# WXD_SCHEMA_LOCATION_BASE=s3a://iceberg-bucket/dbt_demo

# Optional Spark-only demo schemas. These intentionally do not overlap dbt schemas.
# Spark uses the same CSV files and medallion transformations, but writes to
# spark_demo_* schemas so customers can compare both approaches side by side.
WXD_SPARK_CATALOG=iceberg_data
WXD_SPARK_SCHEMA=spark_demo
WXD_SPARK_ENGINE_ID=spark656
# Reference only (not read by any script — the code uses WXD_SPARK_APPLICATIONS_ENDPOINT
# below). Kept for humans who want the engine's base URL at a glance.
WXD_SPARK_ENGINE_ENDPOINT=https://cpd-cpd-instance.apps.watson.ibmas-zocp-techcluster.org/lakehouse/api/v3/spark_engines/spark656
WXD_SPARK_APPLICATIONS_ENDPOINT=https://cpd-cpd-instance.apps.watson.ibmas-zocp-techcluster.org/lakehouse/api/v3/spark_engines/spark656/applications
WXD_SPARK_ASSET_BUCKET=iceberg-bucket
WXD_SPARK_ASSET_PREFIX=spark_demo
WXD_SPARK_APPLICATION=s3a://iceberg-bucket/spark_demo/app/load_medallion_demo.py
WXD_SPARK_INPUT_BASE=s3a://iceberg-bucket/spark_demo/raw
WXD_SPARK_DRY_RUN=true
# WXD_SPARK_BRONZE_SCHEMA=spark_demo_bronze
# WXD_SPARK_SILVER_SCHEMA=spark_demo_silver
# WXD_SPARK_GOLD_SCHEMA=spark_demo_gold

# Optional: needed only if you upload assets from your workstation to MinIO/S3.
# The MinIO internal endpoint is visible in watsonx.data storage details. In
# this environment the OpenShift service has no external route, so a workstation
# normally uses oc port-forward locally:
# oc -n cpd-instance port-forward svc/ibm-lh-lakehouse-minio-svc 19000:9000
WXD_OBJECT_STORE_INTERNAL_ENDPOINT=http://ibm-lh-lakehouse-minio-svc.cpd-instance.svc.cluster.local:9000
WXD_OBJECT_STORE_ENDPOINT=http://127.0.0.1:19000
# You can set these manually, or let scripts/upload_spark_assets.py read them
# from the OpenShift secret below when you are logged in with oc.
# WXD_OBJECT_STORE_ACCESS_KEY=<minio-access-key>
# WXD_OBJECT_STORE_SECRET_KEY=<minio-secret-key>
WXD_OBJECT_STORE_REGION=us-east-1
WXD_OBJECT_STORE_SSL_VERIFY=false
WXD_OBJECT_STORE_AUTO_PORT_FORWARD=true
WXD_OBJECT_STORE_SERVICE=ibm-lh-lakehouse-minio-svc
WXD_OBJECT_STORE_SERVICE_PORT=9000
WXD_OPENSHIFT_NAMESPACE=cpd-instance
# Optional: pin the oc kubeconfig context for all oc calls (secret read +
# port-forward). Leave unset to use the current context. Set it so a stray
# default context can't point the uploader at the wrong cluster.
# WXD_OPENSHIFT_CONTEXT=admin
WXD_OBJECT_STORE_SECRET_NAME=ibm-lh-minio-secret
WXD_OBJECT_STORE_ACCESS_KEY_NAME=LH_S3_ACCESS_KEY
WXD_OBJECT_STORE_SECRET_KEY_NAME=LH_S3_SECRET_KEY

# ---------------------------------------------------------------------------
# PostgreSQL reporting (ibmas_reporting database + schema)
#
# These values are written automatically by:
#   bash scripts/provision_pg_reporting.sh
#
# That script connects to the CPD-bundled PostgreSQL via 'oc exec', creates the
# ibmas_reporting database + schema + a dedicated ibmas_user, and writes all
# PG_* vars below back into .env.  Run it ONCE before pg_reporting.py.
#
# From a workstation (when not running inside the cluster), open a tunnel first:
#   oc -n cpd-instance port-forward svc/postgresql 15432:5432
# then override: PG_HOST=localhost  PG_PORT=15432  PG_SSL_MODE=disable
# ---------------------------------------------------------------------------
PG_HOST=postgresql.cpd-instance.svc.cluster.local
PG_PORT=5432
PG_DATABASE=ibmas_reporting
PG_USER=ibmas_user
# SECRET — auto-generated by provision_pg_reporting.sh (stored here after first run).
PG_PASSWORD=replace-with-provisioned-password
PG_SSL_MODE=require
# Source gold schema to mirror into the reporting tables (matches WXD_GOLD_SCHEMA).
PG_GOLD_SCHEMA=dbt_demo_gold
# Target schema inside PG_DATABASE (created by provision_pg_reporting.sh + pg_reporting.py init).
PG_REPORTING_SCHEMA=ibmas_reporting

# ---------------------------------------------------------------------------
# Spark REST authentication — REQUIRED before submitting a Spark job
#
# The Spark engine REST API requires a short-lived CPD bearer token.
# Tokens expire after ~12 hours; you MUST refresh before every submit session.
#
# HOW TO GET A FRESH TOKEN (run this before submit_spark_application.py):
#
#   python scripts/get_token.py --export
#
# That script authenticates using WXD_API_KEY + WXD_CPD_USERNAME above, hits
# WXD_CPD_AUTH_URL, and writes the new token directly into .env as
# WXD_SPARK_BEARER_TOKEN. You only need to run it once per session (~12 h).
#
# To check the current token's remaining lifetime without refreshing:
#   python scripts/refresh_token.py --check
#
# If you see HTTP 401 from submit_spark_application.py, your token has expired.
# Re-run get_token.py --export and submit again.
# ---------------------------------------------------------------------------
# SECRET — auto-written by: python scripts/get_token.py --export
WXD_SPARK_BEARER_TOKEN=replace-with-bearer-token-from-get_token-py

# Optional ZenApiKey / password auth fallbacks (rarely needed — use
# get_token.py --export instead to populate WXD_SPARK_BEARER_TOKEN above).
# WXD_ZEN_API_KEY=<software-hub-zen-api-key>
# WXD_CPD_PASSWORD=<software-hub-password>

# ---------------------------------------------------------------------------
# Metabase (BI) — docker-compose-metabase.yml
# Metabase REUSES the WXD_* Presto values above (host, user, API key, catalog,
# instance id, CA cert); nothing is duplicated. The first-run provisioner
# creates the admin login and the Presto data source automatically so the
# `iceberg_data` tables are browsable immediately.
#
# NOTE: Metabase rejects trivially-common passwords, so the literal admin/admin
# used by Airflow is NOT accepted — these defaults are the closest equivalent.
MB_SETUP_EMAIL=admin@admin.com
MB_SETUP_PASSWORD=admin12345
MB_SITE_NAME=watsonx.data medallion demo
MB_DB_NAME="watsonx.data (Presto)"
# Optional: pin Metabase to a single schema under the catalog. Leave UNSET to
# browse every schema in iceberg_data (dbt_demo_*, spark_demo_*, spark_demo_cpdctl_raw).
# WXD_METABASE_SCHEMA=dbt_demo_gold

# Optional: OpenMetadata dbt artifact publishing.
# OpenMetadata reads dbt Core artifacts to show dbt models, lineage, tags, and
# test results in its UI. Local artifacts are staged under openmetadata/dbt-artifacts.
WXD_DBT_ARTIFACT_DIR=openmetadata/dbt-artifacts
WXD_DBT_ARTIFACT_BUCKET=iceberg-bucket
WXD_DBT_ARTIFACT_PREFIX=openmetadata/dbt-artifacts/dbt_demo

# ---------------------------------------------------------------------------
# Optional: Databand (IBM Data Observability) dbt-run tracking — dbt only,
# no Airflow involved (Airflow-DAG-level tracking was tested and found broken
# on Airflow 3.x, see airflow/README.md). Off by default (unset
# DBND__CORE__DATABAND_URL = no-op). Fill in both values from your Databand
# tenant (Profile / access-token page), then:
#   python3 scripts/report_dbt_to_databand.py --dry-run   # validate, no side effects
#   python3 scripts/report_dbt_to_databand.py              # actually send
# See README.md "Databand (optional dbt run tracking)" for details.
# DBND__CORE__DATABAND_URL=https://<your-tenant>.databand.ai
# SECRET — Databand access token (Profile -> API tokens in the Databand UI).
# DBND__CORE__DATABAND_ACCESS_TOKEN=replace-with-your-databand-access-token

# ---------------------------------------------------------------------------
# Confluent Streaming Stack (confluent/ folder)
# Fourth approach alongside dbt, Spark, and cpdctl — Kafka + Flink + Iceberg.
#
# PREREQUISITE — run once to create the OpenShift Route that exposes MinIO to Docker:
#   bash confluent/scripts/expose_minio_route.sh
# The script prints the Route URL; paste it as WXD_OBJECT_STORE_ENDPOINT below.
# Without this Route, Flink cannot reach iceberg-bucket from inside Docker.
#
# After running the Route script, WXD_OBJECT_STORE_ENDPOINT (already defined above)
# must be updated to the MinIO OpenShift Route URL. The Route uses edge TLS termination
# but the expose_minio_route.sh script also patches insecureEdgeTerminationPolicy=Allow
# so that Docker containers (which cannot verify the cluster CA) can use plain HTTP:
#   WXD_OBJECT_STORE_ENDPOINT=http://ibm-lh-minio-route-cpd-instance.apps.watson.ibmas-zocp-techcluster.org
# NOTE: insecureEdgeTerminationPolicy=Allow is already set — HTTP access is enabled.
#
# New credentials needed only for the Confluent path:
# ---------------------------------------------------------------------------

# OpenShift login for expose_minio_route.sh — three options, pick one:
#
#   Option A — pin an existing kubeconfig context (fastest, no password stored):
# WXD_OPENSHIFT_CONTEXT=admin
#
#   Option B — bearer token (generate with: oc whoami -t):
# WXD_OC_TOKEN=replace-with-your-oc-token
#
#   Option C — username + password (kubeadmin or LDAP user):
# WXD_OC_USER=kubeadmin
# WXD_OC_PASSWORD=replace-with-kubeadmin-password

# Iceberg schema for Flink-written silver tables (default: confluent_demo_silver).
# Tables land in iceberg_data.confluent_demo_silver.confluent_silver_* after
# register_table. Only CONFLUENT_SILVER_SCHEMA and the oc login vars above are
# new — all other Confluent services reuse existing WXD_* vars above.
CONFLUENT_SILVER_SCHEMA=confluent_demo_silver

# Iceberg REST catalog URL used by confluent-prep (Phase B) to discover
# metadata_location before calling register_table. Override only if you run
# prep_iceberg_schemas.py outside Docker (default points to container name).
# ICEBERG_REST_URL=http://confluent-iceberg-rest:8181

# ---------------------------------------------------------------------------
# Confluent GOLD layer (NEW — closes the 3-way parity loop)
#
# Flink writes the SILVER tables (confluent_demo_silver). The GOLD marts on top
# are built afterwards by a separate engine and land in their OWN schema so they
# sit next to dbt's gold_* and Spark's spark_gold_* marts for side-by-side
# comparison. The three Confluent gold marts are:
#     confluent_gold_daily_sales
#     confluent_gold_category_performance
#     confluent_gold_customer_360
# They use the EXACT same business logic as dbt's gold models (dbt is the
# source of truth) so all four approaches must produce identical numbers.
# ---------------------------------------------------------------------------

# Iceberg schema that holds the Confluent gold marts (default: confluent_demo_gold).
CONFLUENT_GOLD_SCHEMA=confluent_demo_gold

# Which engine BUILDS the Confluent gold marts. Both options read the same
# confluent_demo_silver tables and write the same confluent_demo_gold marts —
# this var only chooses HOW the work runs, so a demo can compare the two:
#   spark      — (default) a watsonx.data Spark job runs the gold SQL. Fast to
#                set up, code-first, reuses the existing Spark engine + assets.
#   datastage  — IBM DataStage flow runs the same logic as a visual, no-code ETL
#                pipeline in the CPD project (see WXD_DATASTAGE_* below). Shows
#                the "enterprise GUI ETL" story against the same data.
CONFLUENT_GOLD_ENGINE=spark

# Confluent Schema Registry URL. Two different values depending on WHERE the
# caller runs (this is a common gotcha):
#   - From your workstation / host shell  → use the published host port below.
#   - From INSIDE a Docker service on the confluent compose network
#                                         → use http://confluent-schema-registry:8081
# Scripts that run on the host use this var; in-container services should use
# the internal name instead.
SCHEMA_REGISTRY_URL=http://localhost:28081

# DataStage project (only used when CONFLUENT_GOLD_ENGINE=datastage). This is an
# existing CPD project that already contains the gold ETL flow. The project is
# addressed by its stable GUID; the human-readable name is kept for reference.
# Auth reuses WXD_API_KEY + WXD_CPD_USERNAME (cpadmin) and the WXD_CPD_HOST above.
WXD_DATASTAGE_PROJECT_ID=2d2415ea-71b5-4215-a7b6-b32a4889611e
WXD_DATASTAGE_PROJECT_NAME=ibmas-ingest-demo

# ---------------------------------------------------------------------------
# Cluster reference (current demo environment — EXAMPLE values, override for
# your cluster)
#
# These document the ONE cluster this demo was last run against. They are
# EXAMPLES: nothing in the code hardcodes them — every script reads hosts/users
# from the WXD_* vars above. Change them (or the vars above) to point at your
# own watsonx.data / IBM Software Hub cluster.
#
# There are TWO different networks to keep straight:
#
#   1. EXTERNAL network (from your laptop, over the internet/VPN):
#        - Bastion / jump host IP : 9.82.206.23
#            The SSH jump box used to reach the OpenShift cluster from outside.
#            You 'ssh cpadmin@9.82.206.23' (or tunnel through it) to get oc
#            access. This is a raw IP because it lives outside cluster DNS.
#        - MinIO OpenShift Route  : the externally-reachable HTTP URL created by
#            confluent/scripts/expose_minio_route.sh. This is how Docker/Flink
#            on your laptop reach the object store. Example value (also set as
#            WXD_OBJECT_STORE_ENDPOINT above when the Route exists):
#              http://ibm-lh-minio-route-cpd-instance.apps.watson.ibmas-zocp-techcluster.org
#
#   2. IN-CLUSTER network (DNS names under the cluster's app domain):
#        - Cluster app domain     : apps.watson.ibmas-zocp-techcluster.org
#            The wildcard domain every OpenShift Route/service hostname hangs
#            off (e.g. the Presto host WXD_HOST, the CPD host WXD_CPD_HOST, the
#            console and API endpoints above all end in this domain). Resolvable
#            once you are on the cluster network / VPN.
#        - In-cluster MinIO svc   : ibm-lh-lakehouse-minio-svc.cpd-instance.svc.cluster.local:9000
#            Only reachable from INSIDE the cluster (see
#            WXD_OBJECT_STORE_INTERNAL_ENDPOINT above).
#
#   Login user: cpadmin
#        The IBM Software Hub / CPD admin user for this environment. It is the
#        value of WXD_CPD_USERNAME above and the SSH user on the bastion. Its
#        API key (WXD_API_KEY) authenticates Presto, Spark, and DataStage calls.
#
# WHICH VARS ARE EXTERNAL vs IN-CLUSTER:
#   External-network facing : WXD_HOST, WXD_CPD_HOST, WXD_CPD_AUTH_URL,
#       WXD_OPENSHIFT_CONSOLE, WXD_OPENSHIFT_API, WXD_OBJECT_STORE_ENDPOINT
#       (MinIO Route), SCHEMA_REGISTRY_URL, the bastion IP — all reached from
#       your laptop.
#   In-cluster only         : WXD_OBJECT_STORE_INTERNAL_ENDPOINT, the
#       *.svc.cluster.local service names, the in-container
#       confluent-schema-registry:8081 / confluent-iceberg-rest:8181 names.
# ---------------------------------------------------------------------------
# CLUSTER_BASTION_HOST=9.82.206.23
# CLUSTER_APP_DOMAIN=apps.watson.ibmas-zocp-techcluster.org
