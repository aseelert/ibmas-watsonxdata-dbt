              "stageName": "lakehouse",
              "connectionName": "ibmas-presto"
            },
            "properties": {
              "read_mode": "select",
              "select_statement": "WITH m AS ( SELECT customer_id,  count(distinct case when status='completed' then order_id end) completed_orders,  count(distinct case when status='returned'  then order_id end) returned_orders,  count(distinct case when status='pending'   then order_id end) pending_orders,  count(distinct case when status='cancelled' then order_id end) cancelled_orders,  cast(coalesce(sum(case when status='completed' then net_amount else 0 end),0)    as decimal(14,2)) lifetime_value,  max(case when status='completed' then order_ts end) last_completed_order_ts,  max(order_ts) last_activity_ts  FROM iceberg_data.datastage_demo_silver_v2.silver_sales_enriched GROUP BY customer_id) SELECT c.customer_id, c.first_name, c.last_name, c.email, c.country, c.signup_date,  coalesce(m.completed_orders,0) completed_orders,  coalesce(m.returned_orders, 0) returned_orders,  coalesce(m.pending_orders,  0) pending_orders,  coalesce(m.cancelled_orders,0) cancelled_orders,  coalesce(m.lifetime_value,  0) lifetime_value,  m.last_completed_order_ts, m.last_activity_ts FROM iceberg_data.datastage_demo_silver_v2.silver_customers c LEFT JOIN m ON c.customer_id = m.customer_id",
              "outputAcpShouldHide": true,
              "enableFlowAcpControl": true,
              "node_number": 0,
              "node_count": 1
            }
          }
